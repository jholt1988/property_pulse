# Backend
# Supabase mode (recommended): use DIRECT Postgres connection for Prisma migrate deploy.
# Example format:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?schema=public
# SHADOW_DATABASE_URL can point to a separate DB or be omitted if not used in deploy flow.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
SHADOW_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME_SHADOW?schema=public
JWT_SECRET=replace-with-long-random-secret
ALLOWED_ORIGINS=https://app.example.com
PORT=3001

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend build arg
VITE_API_URL=/api

# MIL safe defaults
MIL_WRAPPER_ENABLED=false
MIL_ENCRYPT_AT_REST_ENABLED=false
MIL_AUDIT_PERSIST_ENABLED=false
