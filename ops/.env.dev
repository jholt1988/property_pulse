# PMS local development profile (Docker localdb mode)
# Use with docker compose --env-file ops/.env.dev up -d --build

# Backend
DATABASE_URL=postgresql://pms:pms@postgres:5432/pms?schema=public
SHADOW_DATABASE_URL=postgresql://pms:pms@postgres:5432/pms_shadow?schema=public
JWT_SECRET=dev-only-change-me
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
PORT=3001

# Frontend
VITE_API_URL=/api

# Optional integrations (leave blank if unused)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stability/noise controls for local dev
DISABLE_WORKFLOW_SCHEDULER=true
MONITORING_ENABLED=false

# MIL defaults for local bring-up
MIL_WRAPPER_ENABLED=true
MIL_ENCRYPT_AT_REST_ENABLED=false
MIL_AUDIT_PERSIST_ENABLED=false
