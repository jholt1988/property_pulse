generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packs           Pack[]
  packActivations PackActivation[]
  edgeOverlays    CrossRiskTenantEdgeOverlay[]
  actionIntents   ActionIntent[]
  auditEvents     AuditEvent[]
  sdOutcomes      SecondaryDamageOutcome[]
}

enum PackKind {
  GLOBAL_COUPLING_CEILINGS
  CROSS_RISK_GLOBAL
  CROSS_RISK_TENANT_EDGE_OVERLAY
  SHOCK_VENDOR_LEADTIME
  SECONDARY_DAMAGE_GLOBAL
  SECONDARY_DAMAGE_TENANT
  WORKFLOW_POLICY_GLOBAL
  WORKFLOW_POLICY_TENANT
}

model Pack {
  id          String   @id @default(cuid())
  tenantId    String?
  kind        PackKind
  version     String
  hash        String   @unique
  status      String
  payloadJson Json
  createdAt   DateTime @default(now())

  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  activations PackActivation[]
}

model PackActivation {
  id          String   @id @default(cuid())
  tenantId    String?
  packId      String
  activatedAt DateTime @default(now())
  boundaryTag String
  reason      String

  pack   Pack    @relation(fields: [packId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])
}

enum CrossRiskEdge {
  M_to_R
  R_to_M
  M_to_V
  R_to_V
}

model CrossRiskTenantEdgeOverlay {
  id             String        @id @default(cuid())
  tenantId       String
  edge           CrossRiskEdge
  parentPackHash String
  version        String
  status         String
  deltaBeta      Float
  deltaAlpha     Float
  windowDays     Int
  decayLambda    Float
  neff           Float
  metricsJson    Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, edge, version])
  @@index([tenantId, edge, status])
}

enum ActionTier {
  TIER_1
  TIER_2
  TIER_3
}

enum IntentStatus {
  DETECTED
  QUEUED
  APPROVED
  EXECUTED
  COMPLETED
  RESOLVED
  SUPERSEDED
}

model ActionIntent {
  id                String       @id @default(cuid())
  tenantId          String
  propertyId        String?
  unitId            String?
  riskType          String
  horizonDays       Int
  percentile        Int
  rawProbability    Float
  expectedLoss90d   Float?
  amplified         Boolean      @default(false)
  recommendedAction String
  priorityScore     Float
  tier              ActionTier
  status            IntentStatus @default(DETECTED)
  bundleHash        String?
  governanceJson    Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenant            Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, tier])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  type      String
  payload   Json
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, type])
}

enum BuildingVintageBucket {
  PRE_1970
  YEAR_1970_1989
  YEAR_1990_2009
  YEAR_2010_PLUS
  UNKNOWN
}

enum PropertyClassBucket {
  A
  B
  C
  UNKNOWN
}

model SecondaryDamageOutcome {
  id              String                @id @default(cuid())
  tenantId        String
  propertyId      String?
  unitId          String?
  assetGroup      String
  eventType       String
  occurredAt      DateTime
  directCostUsd   Float
  downtimeDays    Int?
  vintageBucket   BuildingVintageBucket @default(UNKNOWN)
  classBucket     PropertyClassBucket   @default(UNKNOWN)
  bundleHash      String?
  taxonomyVersion String?
  createdAt       DateTime              @default(now())
  tenant          Tenant                @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventType])
}
