{
  "name": "pms-master",
  "private": true,
  "scripts": {
    "property-os": "pnpm --filter property-os",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter tenant_portal_backend --filter tenant_portal_app dev",
    "dev:workspace": "pnpm -r dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "bg:workflow": "bash scripts/background-workflow.sh",
    "bg:workflow:quick": "bash scripts/background-workflow.sh --quick",
    "env:down": "docker compose down",
    "env:dev": "docker compose --env-file ops/.env.dev up -d --build",
    "env:supabase": "docker compose --env-file ops/.env.supabase up -d --build",
    "env:logs:backend": "docker compose logs --tail=150 backend",
    "env:logs:frontend": "docker compose logs --tail=150 frontend",
    "env:health": "docker compose exec frontend sh -lc \"wget -S -O- http://backend:3001/api/health | head -n 40\""
  },
  "dependencies": {
    "@types/node": "^24.11.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "pnpm": "^8.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.0.4"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  }
}
