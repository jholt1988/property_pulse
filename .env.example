# Client-facing API base URL used by browser calls.
# pms-master default: route through Next.js proxy to avoid CORS issues.
NEXT_PUBLIC_API_BASE_URL=/api/backend

# Server-side backend origin for Next.js rewrite proxy (no trailing slash).
# pms-master backend default local origin:
BACKEND_API_ORIGIN=http://127.0.0.1:3001

# Optional runtime flags
# NEXT_PUBLIC_APP_ENV=production
