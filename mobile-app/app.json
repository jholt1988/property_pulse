{
  "expo": {
    "name": "Property Pulse",
    "slug": "property-pulse-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.propertypulse.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.propertypulse.mobile"
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:3001/api",
      "eas": {
        "projectId": "c6ab1986-a036-4567-9df3-39b7df61c215"
      }
    }
  }
}
