  APPROVED
  REJECTED
  COMPLETED
}

model ScheduleEvent {
  id          Int               @id @default(autoincrement())
  type        ScheduleEventType
  title       String
  date        DateTime
  priority    EventPriority     @default(MEDIUM)
  description String?
  status      String?           @default("SCHEDULED")
  property    Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId  String?           @db.Uuid
  unit        Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId      String?           @db.Uuid
  tenant      User?             @relation("ScheduleEventTenant", fields: [tenantId], references: [id], onDelete: SetNull)
  tenantId    String?           @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([type])
  @@index([priority])
  @@index([propertyId])
}

enum ScheduleEventType {
  TOUR
  MOVE_IN
  MOVE_OUT
  LEASE_EXPIRATION
  LEASE_RENEWAL
  INSPECTION
  MAINTENANCE
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model QuickBooksConnection {
  id                    Int      @id @default(autoincrement())
  userId                String   @db.Uuid
  organizationId        String   @db.Uuid
  companyId             String
  accessToken           String
  refreshToken          String
  tokenExpiresAt        DateTime
  refreshTokenExpiresAt DateTime
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user         User         @relation("UserQuickBooksConnections", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, companyId])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("quickbooks_connections")
}

// Workflow Execution Models
model WorkflowExecution {
  id          String    @id @default(uuid())
  workflowId  String
  status      String // PENDING, RUNNING, COMPLETED, FAILED, CANCELLED
  input       Json
  output      Json      @default("{}")
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  steps WorkflowExecutionStep[]

  @@index([workflowId, status])
  @@index([startedAt])
  @@map("workflow_executions")
}

model WorkflowExecutionStep {
  id          Int       @id @default(autoincrement())
  executionId String
  stepId      String
  status      String // PENDING, RUNNING, COMPLETED, FAILED, SKIPPED
  input       Json      @default("{}")
  output      Json      @default("{}")
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, stepId])
  @@index([executionId])
  @@map("workflow_execution_steps")
}

model DeadLetterQueue {
  id          String    @id @default(uuid())
  workflowId  String
  executionId String
  input       Json
  error       String
  errorCode   String
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([workflowId])
  @@index([createdAt])
  @@map("dead_letter_queue")
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model AgentRun {
  id        String         @id @default(uuid())
  agentName String // "PropertyOpsOrchestrator", "RepairEstimator", etc.
  routeTo   String? // optional: "MaintenanceTriage", etc.
  status    AgentRunStatus @default(RUNNING)

  // Primary payloads (store what the agent saw + returned)
  input  Json
  output Json?
  error  String?

  // Tracing/correlation
  traceId String?

  // Context links (optional)
  initiatedById String? @db.Uuid
  tenantId      String? @db.Uuid
  propertyId    String? @db.Uuid
  unitId        String? @db.Uuid
  leaseId       String? @db.Uuid
  requestId     String? @db.Uuid // MaintenanceRequest.id

  initiatedBy User? @relation("AgentRunInitiatedBy", fields: [initiatedById], references: [id], onDelete: SetNull)
  tenant      User? @relation("AgentRunTenant", fields: [tenantId], references: [id], onDelete: SetNull)

  property Property?           @relation("AgentRunProperty", fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?               @relation("AgentRunUnit", fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?              @relation("AgentRunLease", fields: [leaseId], references: [id], onDelete: SetNull)
  request  MaintenanceRequest? @relation("AgentRunRequest", fields: [requestId], references: [id], onDelete: SetNull)

  toolCalls AgentToolCall[]

  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  approvalTasks ApprovalTask[]

  @@index([agentName, status, startedAt])
  @@index([propertyId])
  @@index([tenantId])
  @@index([requestId])
  @@index([traceId])
}

model AgentToolCall {
  id         Int    @id @default(autoincrement())
  agentRunId String
  toolName   String // "get_property_context", "create_work_order", etc.

  // Tool I/O
  input        Json
  output       Json?
  ok           Boolean @default(false)
  errorCode    String?
  errorMessage String?
  latencyMs    Int?

  createdAt DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, toolName])
  @@index([toolName, createdAt])
}

enum CommunicationChannel {
  UI
  SMS
  EMAIL
  INTERNAL
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

model CommunicationLog {
  id        Int                    @id @default(autoincrement())
  channel   CommunicationChannel
  direction CommunicationDirection

  to       String
  from     String
  subject  String?
  message  String
  metadata Json?

  // Optional linking
  tenantId   String? @db.Uuid
  propertyId String? @db.Uuid
  unitId     String? @db.Uuid
  leaseId    String? @db.Uuid
  requestId  String? // MaintenanceRequest.id

  createdById String? @db.Uuid

  tenant    User?               @relation("CommunicationLogTenant", fields: [tenantId], references: [id], onDelete: SetNull)
  createdBy User?               @relation("CommunicationLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  property  Property?           @relation("CommunicationLogProperty", fields: [propertyId], references: [id], onDelete: SetNull)
  unit      Unit?               @relation("CommunicationLogUnit", fields: [unitId], references: [id], onDelete: SetNull)
  lease     Lease?              @relation("CommunicationLogLease", fields: [leaseId], references: [id], onDelete: SetNull)
  request   MaintenanceRequest? @relation("CommunicationLogRequest", fields: [requestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([propertyId, createdAt])
  @@index([requestId, createdAt])
  @@index([channel, direction, createdAt])
}

model PricebookLaborRate {
  id              Int      @id @default(autoincrement())
  trade           String // keep as String so you can expand without migrations
  task            String
  zipCode         String // "67203"
  hourlyLowCents  Int
  hourlyHighCents Int
  currency        String   @default("USD")
  sourceNote      String?  @default("internal pricebook")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([trade, task, zipCode])
  @@index([trade, zipCode])
  @@index([task])
}

model PricebookMaterialPrice {
  id             Int      @id @default(autoincrement())
  item           String
  unit           String // "each", "ft", "sqft", etc.
  zipCode        String? // optional region-specific pricing
  unitPriceCents Int
  currency       String   @default("USD")
  sourceNote     String?  @default("internal pricebook")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([item])
  @@index([zipCode])
}

model TransactionImportBatch {
  id           String  @id @default(uuid())
  source       String // "csv", "quickbooks", etc.
  fileName     String?
  importedById String? @db.Uuid
  metadata     Json?

  importedBy User?    @relation("TransactionImportBy", fields: [importedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  transactions BankTransaction[]

  @@index([source, createdAt])
  @@index([importedById, createdAt])
}

model BankTransaction {
  id          String   @id @default(uuid())
  batchId     String?
  date        DateTime
  vendor      String
  amountCents Int
  currency    String   @default("USD")
  memo        String?
  category    String?
  confidence  Float?

  propertyId   String? @db.Uuid
  unitId       String? @db.Uuid
  recordedById String? @db.Uuid

  raw Json?

  batch      TransactionImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  property   Property?               @relation("BankTransactionProperty", fields: [propertyId], references: [id], onDelete: SetNull)
  unit       Unit?                   @relation("BankTransactionUnit", fields: [unitId], references: [id], onDelete: SetNull)
  recordedBy User?                   @relation("BankTransactionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([propertyId, date])
  @@index([batchId])
}

model MaintenanceRequestDocument {
  id         Int      @id @default(autoincrement())
  requestId  String   @db.Uuid
  documentId Int
  createdAt  DateTime @default(now())

  request  MaintenanceRequest @relation("MaintenanceRequestDocuments", fields: [requestId], references: [id], onDelete: Cascade)
  document Document           @relation("MaintenanceRequestDocumentsDoc", fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([requestId, documentId])
  @@index([requestId])
  @@index([documentId])
}

enum ApprovalTaskStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
  CANCELLED
}

enum ApprovalActionType {
  SEND_MESSAGE
  ASSIGN_TECHNICIAN
  CREATE_SCHEDULE_EVENT
  UPDATE_WORK_ORDER
}

model ApprovalTask {
  id     String             @id @default(uuid()) @db.Uuid
  status ApprovalTaskStatus @default(PENDING)

  // optional linkage to agent observability (if you added AgentRun)
  agentRunId String?

  // common linkage for filtering/UX
  tenantId    String? @db.Uuid
  propertyId  String? @db.Uuid
  unitId      String? @db.Uuid
  leaseId     String? @db.Uuid
  workOrderId String? @db.Uuid // MaintenanceRequest.id after UUID migration

  // who created/approved
  createdById    String?   @db.Uuid
  decidedById    String?   @db.Uuid
  decidedAt      DateTime?
  executedAt     DateTime?
  executionError String?

  title   String
  summary String?
  // Core payload: list of actions to execute after approval
  actions Json
  // Store tool outputs / execution artifacts
  results Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations (will work after User/Property/Unit/Lease/MaintenanceRequest move to UUID)
  createdBy User? @relation("ApprovalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  decidedBy User? @relation("ApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  tenant   User?               @relation("ApprovalTenant", fields: [tenantId], references: [id], onDelete: SetNull)
  property Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  request  MaintenanceRequest? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  agentRun AgentRun?           @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([tenantId, createdAt])
  @@index([propertyId, createdAt])
  @@index([workOrderId])
  @@index([agentRunId])
}
