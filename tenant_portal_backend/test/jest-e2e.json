{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.e2e\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true, "diagnostics": false }]
  },
  "setupFilesAfterEnv": ["<rootDir>/test/setup.ts"],
  "testEnvironment": "node",
  "forceExit": true,
  "detectOpenHandles": false,
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverage": false,
  "coverageDirectory": "<rootDir>/coverage/e2e",
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/test/",
    "/dist/",
    "\\.spec\\.ts$",
    "\\.e2e\\.spec\\.ts$"
  ],
  "coverageReporters": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 0,
      "functions": 0,
      "lines": 0,
      "statements": 0
    }
  },
  "collectCoverageFrom": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.module.ts",
    "!src/main.ts",
    "!src/index.ts"
  ]
}
